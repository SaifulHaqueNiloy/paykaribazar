rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 && // 5MB max
        request.resource.contentType.matches('image/.*');
    }

    // Product images
    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        (get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'reseller') &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB max
        request.resource.contentType.matches('image/.*');
    }

    // Prescriptions (private)
    match /prescriptions/{userId}/{allPaths=**} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024;
    }

    // Backups (admin only)
    match /backups/{allPaths=**} {
      allow read: if request.auth != null && get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if false; // Only via Admin SDK
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
